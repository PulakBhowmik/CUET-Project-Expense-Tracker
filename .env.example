# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored and must never be committed.

# ---- Database (free hosted Postgres — Supabase) ----
# In Supabase: Project Settings -> Database -> "Connection string".
# DATABASE_URL = the "Transaction" pooler URI (host ends in ...pooler.supabase.com,
#   port 6543). Used by the app at runtime (works well on Vercel serverless).
# DIRECT_URL   = the "Direct connection" URI (port 5432). Used only for running
#   database migrations. Both use the same database password.
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ---- Auth.js ----
# Generate with:  openssl rand -base64 32   (or: npx auth secret)
AUTH_SECRET="replace-with-a-long-random-string"
# Optional; Auth.js infers the URL in most deployments (e.g. Vercel).
# AUTH_URL="http://localhost:3000"

# ---- Email delivery (for sign-in codes) ----
# LOCAL DEVELOPMENT: leave these blank. The 6-digit code is printed straight to
# your terminal, so you can test the whole sign-up flow without an email
# account. REQUIRED IN PRODUCTION — the app refuses to start sending otherwise.
#
# Any SMTP provider works. Two easy options:
#
# A) Gmail (free, sends to anyone):
#      1. Enable 2-Step Verification on your Google account.
#      2. Create an App Password: https://myaccount.google.com/apppasswords
#      3. SMTP_HOST="smtp.gmail.com", SMTP_PORT="587",
#         SMTP_USER="you@gmail.com", SMTP_PASSWORD=<the 16-char app password>
#
# B) Brevo / Mailjet free tier — no domain needed; copy their SMTP credentials.
#
# Note: Resend's free tier can only send to YOUR OWN address unless you own a
# domain, so it won't work for inviting classmates.
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="you@gmail.com"
# SMTP_PASSWORD="your-16-char-app-password"
# SMTP_FROM="CUET Expense Splitter <you@gmail.com>"

# ---- CUET restrictions (configurable) ----
# Only emails matching this regex may request a code, create an account,
# sign in, or be invited.
# IMPORTANT: use SINGLE backslashes here (e.g. \.), not double. Values in a
# .env file are read literally — "\\." would match a literal backslash and
# break the pattern.
CUET_EMAIL_REGEX="^u2204[0-9]{3}@student\.cuet\.ac\.bd$"

# ---- Invitations ----
# Secret used to HMAC-hash invitation tokens before storage.
INVITATION_TOKEN_SECRET="replace-with-a-long-random-string"
# Invitation lifetime in hours (default 168 = 7 days).
INVITATION_TTL_HOURS="168"

# ---- Live updates ----
# The app keeps balances fresh with lightweight polling through the normal
# (authorized) server — no extra keys required. These optional Supabase Realtime
# keys are only needed if you later switch to websocket push updates.
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ---- Rate limiting ----
RATE_LIMIT_INVITES_PER_MIN="10"
RATE_LIMIT_ACCEPT_PER_MIN="20"
